<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".pantalla_estadisticas">

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:ignore="MissingConstraints"
        android:backgroundTint="@color/greenti"
        android:background="@color/greenti">
        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/ib_backstats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:src="@drawable/ic_back"
                android:backgroundTint="@color/greenti"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="5"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:layout_marginRight="10dp"
                android:text="@string/estadistica"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="25sp"
                android:textStyle="bold"/>

        </TableRow>

    </TableLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="80dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/mulishregular"
            android:text="@string/welcome_stats"
            android:textSize="20sp"
            android:textAlignment="center"/>

        <TextView
            android:layout_marginTop="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/mulishregular"
            android:text="@string/select_stats"
            android:textSize="18sp" />


        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="15dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/granja"
                    android:fontFamily="@font/mulishregular"
                    android:textAlignment="center"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_marginTop="15dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/lote"
                    android:fontFamily="@font/mulishregular"
                    android:textAlignment="center"
                    android:textSize="18sp"/>
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="15dp">

                <Spinner
                    android:id="@+id/spGranja"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dp"
                    android:layout_marginLeft="10dp"/>
                <Spinner
                    android:id="@+id/spLote"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="10dp"
                    android:layout_marginLeft="10dp"/>
            </TableRow>

        </TableLayout>


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:ignore="MissingClass"></ScrollView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" >

                    <RadioGroup
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent" >

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            tools:ignore="UselessParent">


                            <RadioButton
                                android:id="@+id/rb_brocoli"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/brocoli"
                                android:fontFamily="@font/mulishregular"
                                android:textSize="15sp"
                                android:layout_marginEnd="10dp"/>

                            <RadioButton
                                android:id="@+id/rb_lechuga"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lechuga"
                                android:fontFamily="@font/mulishregular"
                                android:textSize="15sp"
                                android:layout_marginEnd="10dp"/>


                            <RadioButton
                                android:id="@+id/rb_berries"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/berries"
                                android:fontFamily="@font/mulishregular"
                                android:textSize="15sp"
                                android:layout_marginEnd="10dp"/>


                            <RadioButton
                                android:id="@+id/rb_maiz"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/maiz"
                                android:fontFamily="@font/mulishregular"
                                android:textSize="15sp"
                                android:layout_marginEnd="10dp"/>
                        </LinearLayout>


                    </RadioGroup>
                </HorizontalScrollView>
        <LinearLayout
            android:id="@+id/ll_chart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
        </LinearLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>