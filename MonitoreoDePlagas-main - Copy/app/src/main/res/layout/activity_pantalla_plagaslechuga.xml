<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".pantalla_plagaslechuga">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">

        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <TextView
            android:id="@+id/tv_Ubicacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/mulishregular"
            android:text="@string/msj_ubicaction"
            android:textAlignment="center"
            android:textSize="12dp"
            android:visibility="gone" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/mulishregular"
                android:text="@string/msj_pantallaconteo"
                android:textSize="20dp" />

            <Space
                android:layout_width="2sp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_idPlagas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/mulishregular"
                android:text=""
                android:textSize="20dp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/yellowselection"
            android:fontFamily="@font/mulishregular"
            android:text="@string/msj_elegirplaga"
            android:textAlignment="center"
            android:textSize="20dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

    </LinearLayout>

    <Space
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:ignore="MissingConstraints" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/ContenedorBoton"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:gravity="center_horizontal|center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/boton_otrasplagaslechuga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    android:drawableEnd="@drawable/ic_add"
                    android:gravity="center_horizontal|center_vertical" />

                <Space
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvPlagas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/mulishregular"
                    android:text="@string/msj_otrasplagas"
                    android:textSize="17dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/Caja_plagasprincipaleslechuga"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/dorsodiamante"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/DorsoDiamante"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="0dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_dorsodiamante"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Dorso de Diamante"
                            android:scaleType="centerInside"
                            android:src="@mipmap/dorsodiamantegrande" />

                        <TextView
                            android:id="@+id/tv_dorsodiamante"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_dorsodiamante"
                            android:textAlignment="center"
                            android:textSize="12dp" />

                    </LinearLayout>

                    <include layout="@layout/registrodd" />
                </LinearLayout>

                <include layout="@layout/ldd" />

                <LinearLayout
                    android:id="@+id/falsomedidor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/FalsoMedidor"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_falsomedidor"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Falso Medidor"
                            android:scaleType="centerInside"
                            android:src="@mipmap/falsomedidor" />

                        <TextView
                            android:id="@+id/tv_falsomedidor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_falsomedidor"
                            android:textAlignment="center"
                            android:textSize="15dp" />

                    </LinearLayout>

                    <include layout="@layout/registrofm" />
                </LinearLayout>

                <include layout="@layout/lfm" />

                <LinearLayout
                    android:id="@+id/trips"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <include layout="@layout/registrot" />
                </LinearLayout>

                <include layout="@layout/lt" />

                <LinearLayout
                    android:id="@+id/chinchenysus"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/ChincheNysus"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="0dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_chinchenysus"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Dorso de Diamante"
                            android:scaleType="centerInside"
                            android:src="@mipmap/chinchenysius" />

                        <TextView
                            android:id="@+id/tv_chinchenysus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_chinchenysius"
                            android:textAlignment="center"
                            android:textSize="12dp" />

                    </LinearLayout>

                    <include layout="@layout/registrocn" />
                </LinearLayout>

                <include layout="@layout/lcn" />

                <LinearLayout
                    android:id="@+id/helicoverpa"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/Helicoverpa"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="0dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_helicoverpa"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Dorso de Diamante"
                            android:scaleType="centerInside"
                            android:src="@mipmap/helicoverpa" />

                        <TextView
                            android:id="@+id/tv_helicoverpa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_helicoverpa"
                            android:textAlignment="center"
                            android:textSize="12dp" />

                    </LinearLayout>

                    <include layout="@layout/registrohz" />
                </LinearLayout>

                <include layout="@layout/lhz" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <LinearLayout
                android:id="@+id/Caja_otrasplagaslechuga"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/copitarsia"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/Copitarsia"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_copitarsia"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Gusano Copitarsia"
                            android:scaleType="centerInside"
                            android:src="@mipmap/copitarsia" />

                        <TextView
                            android:id="@+id/tv_copitarsia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_copitarsia"
                            android:textAlignment="center"
                            android:textSize="15dp" />

                    </LinearLayout>

                    <include layout="@layout/registroc" />
                </LinearLayout>

                <include layout="@layout/llc" />

                <LinearLayout
                    android:id="@+id/diabrotica"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/Diabrotica"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_diabrotica"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Diabrotica"
                            android:scaleType="centerInside"
                            android:src="@mipmap/diabrotica" />

                        <TextView
                            android:id="@+id/tv_diabrotica"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_diabrotica"
                            android:textAlignment="center"
                            android:textSize="15dp" />

                    </LinearLayout>

                    <include layout="@layout/registrod" />
                </LinearLayout>

                <include layout="@layout/lld" />

                <LinearLayout
                    android:id="@+id/chicharrita"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <include layout="@layout/registrochi" />
                </LinearLayout>

                <include layout="@layout/llchi" />

                <LinearLayout
                    android:id="@+id/coccinellidae"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/Coccinellidae"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_coccinellidae"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Chicharrita"
                            android:scaleType="centerInside"
                            android:src="@mipmap/coccinellidae" />

                        <TextView
                            android:id="@+id/tv_coccinellidae"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_coccinellidae"
                            android:textAlignment="center"
                            android:textSize="15dp" />

                    </LinearLayout>

                    <include layout="@layout/registrococ" />
                </LinearLayout>

                <include layout="@layout/lcoc" />

                <LinearLayout
                    android:id="@+id/mosquitablanca"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/MosquitaBlanca"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_mosquitablanca"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Chicharrita"
                            android:scaleType="centerInside"
                            android:src="@mipmap/mosquitablanca" />

                        <TextView
                            android:id="@+id/tv_mosquitablanca"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/plaga_mosquitablanca"
                            android:textAlignment="center"
                            android:textSize="15dp" />

                    </LinearLayout>

                    <include layout="@layout/registromb" />
                </LinearLayout>

                <include layout="@layout/lmb" />

                <LinearLayout
                    android:id="@+id/minador"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/Minador"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_minador"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Chicharrita"
                            android:scaleType="centerInside"
                            android:src="@mipmap/minador" />

                        <TextView
                            android:id="@+id/tv_minador"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/enfermedad_minador"
                            android:textAlignment="center"
                            android:textSize="15dp" />

                    </LinearLayout>

                    <include layout="@layout/registrom" />
                </LinearLayout>

                <include layout="@layout/lm" />

                <LinearLayout
                    android:id="@+id/tizon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/Tizon"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/boton_tizon"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:contentDescription="Chicharrita"
                            android:scaleType="centerInside"
                            android:src="@mipmap/tizon" />

                        <TextView
                            android:id="@+id/tv_tizon"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/mulishregular"
                            android:text="@string/enfermedad_tizon"
                            android:textAlignment="center"
                            android:textSize="15dp" />

                    </LinearLayout>

                    <include layout="@layout/registroti" />
                </LinearLayout>

                <include layout="@layout/lti" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="5dp" />

            <LinearLayout
                android:id="@+id/ContenedorReciver"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

            </LinearLayout>

            <Space
                android:layout_width="10dp"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/boton_noplaga"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_noplague" />

                <TextView
                    android:id="@+id/textView6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/mulishregular"
                    android:text="@string/msj_noplaga"
                    android:textAlignment="center"
                    android:textSize="13dp" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />
        </LinearLayout>
    </ScrollView>

    <Space
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:ignore="MissingConstraints" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:persistentDrawingCache="animation"
        android:pointerIcon="arrow"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteY="1741dp">

        <Button
            android:id="@+id/b_EnviarPlagas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="80dp"
            android:layout_marginRight="80dp"
            android:layout_marginBottom="5dp"
            android:backgroundTint="@color/greenti"
            android:text="@string/boton_enviarplagas" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>